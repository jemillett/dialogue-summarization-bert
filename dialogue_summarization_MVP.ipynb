    "tokenizer = BertTokenizer.from_pretrained(MODEL_CHECKPOINT)\n",
    "\n",
    "# The EncoderDecoderModel requires explicit BOS / EOS tokens for the decoder\n",
    "tokenizer.bos_token    = tokenizer.cls_token    # '[CLS]'\n",
